    // ... REST OF YOUR WORKTRACKER CODE ...
</script>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>WorkTracker Pro</title>
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/2618/2618469.png">

    <style>
        :root {
            --primary: #4f46e5; --bg: #f1f5f9; --card: #ffffff; 
            --text: #1e293b; --accent: #059669; --border: #e2e8f0;
        }
        body.dark {
            --bg: #0f172a; --card: #1e293b; --text: #f1f5f9; --border: #334155;
        }
        body { 
            font-family: -apple-system, sans-serif; background: var(--bg); color: var(--text); 
            margin: 0; padding: 10px; display: flex; flex-direction: column; align-items: center; 
            transition: background 0.3s; -webkit-tap-highlight-color: transparent;
        }
        
        .header-box { width: 100%; max-width: 500px; display: flex; flex-direction: column; gap: 10px; margin-bottom: 15px; padding-top: env(safe-area-inset-top); }
        .row { display: flex; gap: 8px; align-items: center; }
        
        select, input { padding: 10px; border-radius: 8px; border: 1px solid var(--border); font-size: 0.9rem; background: var(--card); color: var(--text); outline: none; }
        select { flex-grow: 1; }
        .wage-input { width: 70px; }
        .currency-select { width: 65px; flex-grow: 0; }

        button { padding: 10px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 0.85rem; transition: opacity 0.2s; }
        .btn-job { background: var(--primary); color: white; }
        .btn-mode { background: #94a3b8; color: white; flex: 1; opacity: 0.5; }
        .btn-mode.active { opacity: 1; background: var(--primary); }
        .btn-dark { background: #334155; color: white; border: 1px solid var(--border); }

        .container { background: var(--card); padding: 1rem; border-radius: 1.2rem; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 500px; box-sizing: border-box; }
        
        .labels { display: grid; grid-template-columns: 85px 1fr 1fr 50px 65px 25px; gap: 4px; font-size: 0.55rem; font-weight: bold; color: #64748b; margin-bottom: 5px; text-align: center; text-transform: uppercase; }

        .day-row { display: grid; grid-template-columns: 85px 1fr 1fr 50px 65px 25px; gap: 4px; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); }
        input[type="time"], input[type="number"], input[type="date"] { width: 100%; padding: 6px; font-size: 0.75rem; text-align: center; border: 1px solid var(--border); border-radius: 6px; -webkit-appearance: none; }
        .day-total { font-weight: bold; color: var(--primary); font-size: 0.8rem; text-align: right; }
        
        .footer { margin-top: 1.5rem; padding-top: 1rem; border-top: 3px solid var(--primary); }
        .stat-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
        .grand-total { font-size: 1.4rem; font-weight: 800; color: var(--accent); }
        .remove-btn { color: #ef4444; background: none; font-size: 1.2rem; border: none; padding: 0; }
        
        .add-btn { background: var(--accent); color: white; width: 100%; margin-top: 15px; padding: 15px; font-size: 1rem; }
    </style>
</head>
<body>

<div class="header-box">
    <div class="row">
        <select id="jobSelect" onchange="changeJob()"></select>
        <button class="btn-job" onclick="createNewJob()">+ Job</button>
        <button class="btn-dark" onclick="toggleDark()">🌓</button>
    </div>
    <div class="row">
        <select id="currencySelect" class="currency-select" onchange="updateCurrency(this.value)">
            <option value="$">$</option><option value="€">€</option><option value="£">£</option>
            <option value="kr">kr</option><option value="CHF">CHF</option>
        </select>
        <input type="number" id="wageInput" class="wage-input" placeholder="Wage" oninput="updateWage(this.value)">
        <button class="btn-mode" id="modeWeekly" onclick="setMode('weekly')">Weekly</button>
        <button class="btn-mode" id="modeCustom" onclick="setMode('custom')">Custom</button>
    </div>
    <button style="background:#334155; color:white; width:100%" onclick="exportCSV()">📤 Export for Accounting (CSV)</button>
</div>

<div class="container">
    <h3 id="displayTitle" style="margin: 0 0 15px 0; color: var(--primary); text-align: center;">Timesheet</h3>
    <div class="labels">
        <div>Date</div><div>In</div><div>Out</div><div>Brk</div><div>Total</div><div></div>
    </div>
    <div id="entries-list"></div>
    <button id="addBtn" class="add-btn" onclick="addCustomRow()" style="display:none;">+ Add New Shift</button>

    <div class="footer">
        <div class="stat-row">
            <span>Total Time:</span>
            <span id="grandTotal" class="grand-total">0h 0m</span>
        </div>
        <div class="stat-row">
            <span>Estimated Pay:</span>
            <span id="grandPay" style="font-weight: 800; color: var(--accent); font-size: 1.4rem;">$0.00</span>
        </div>
    </div>
    <button onclick="deleteJob()" style="background:none; color:red; margin-top:30px; font-size:0.7rem; width:100%; opacity:0.3;">Delete Job Permanently</button>
</div>

<script>
    // Initial Data Structure
    let data = JSON.parse(localStorage.getItem('workData_v4')) || {
        currentJob: "Freelance", darkMode: false, currency: "$",
        jobs: {
            "Freelance": { mode: 'weekly', wage: 0,
                weekly: Array.from({length:7}, (_,i)=>({d:['Mon','Tue','Wed','Thu','Fri','Sat','Sun'][i],s:'',e:'',b:0,dt:''})),
                custom: []
            }
        }
    };

    function toggleDark() { data.darkMode = !data.darkMode; save(); }
    function updateWage(val) { data.jobs[data.currentJob].wage = parseFloat(val) || 0; save(); }
    function updateCurrency(val) { data.currency = val; save(); }
    function setMode(m) { data.jobs[data.currentJob].mode = m; save(); }
    function changeJob() { data.currentJob = document.getElementById('jobSelect').value; save(); }

    function createNewJob() {
        const name = prompt("Job Name:");
        if (name && !data.jobs[name]) {
            data.jobs[name] = { mode: 'weekly', wage: 0, weekly: Array.from({length:7}, (_,i)=>({d:['Mon','Tue','Wed','Thu','Fri','Sat','Sun'][i],s:'',e:'',b:0,dt:''})), custom: [] };
            data.currentJob = name; save();
        }
    }

    function updateEntry(index, field, val) {
        const job = data.jobs[data.currentJob];
        const list = job.mode === 'weekly' ? job.weekly : job.custom;
        list[index][field] = (field === 'b') ? parseInt(val) || 0 : val;
        save();
    }

    function addCustomRow() { 
        data.jobs[data.currentJob].custom.push({d:'Extra', s:'', e:'', b:0, dt: new Date().toISOString().split('T')[0]}); 
        save(); 
    }
    function removeRow(i) { data.jobs[data.currentJob].custom.splice(i,1); save(); }
    function deleteJob() { if(confirm("Delete Job?")) { delete data.jobs[data.currentJob]; data.currentJob = Object.keys(data.jobs)[0] || "Freelance"; if(!data.jobs[data.currentJob]) location.reload(); save(); } }

    function save() { localStorage.setItem('workData_v4', JSON.stringify(data)); render(); }

    function render() {
        document.body.className = data.darkMode ? 'dark' : '';
        const job = data.jobs[data.currentJob];
        document.getElementById('displayTitle').innerText = data.currentJob;
        document.getElementById('wageInput').value = job.wage;
        document.getElementById('currencySelect').value = data.currency;
        
        const select = document.getElementById('jobSelect');
        select.innerHTML = '';
        Object.keys(data.jobs).forEach(n => select.innerHTML += `<option value="${n}" ${n===data.currentJob?'selected':''}>${n}</option>`);

        document.getElementById('modeWeekly').className = `btn-mode ${job.mode==='weekly'?'active':''}`;
        document.getElementById('modeCustom').className = `btn-mode ${job.mode==='custom'?'active':''}`;
        document.getElementById('addBtn').style.display = job.mode === 'custom' ? 'block' : 'none';

        const list = job.mode === 'weekly' ? job.weekly : job.custom;
        const container = document.getElementById('entries-list');
        container.innerHTML = '';
        let totalMin = 0;

        list.forEach((entry, i) => {
            let diff = 0;
            if(entry.s && entry.e) {
                const [sH, sM] = entry.s.split(':').map(Number);
                const [eH, eM] = entry.e.split(':').map(Number);
                let startM = sH * 60 + sM;
                let endM = eH * 60 + eM;
                if(endM < startM) endM += 1440;
                diff = Math.max(0, (endM - startM) - (entry.b || 0));
                totalMin += diff;
            }
            container.innerHTML += `<div class="day-row">
                <input type="date" value="${entry.dt || ''}" oninput="updateEntry(${i},'dt',this.value)">
                <input type="time" value="${entry.s}" oninput="updateEntry(${i},'s',this.value)">
                <input type="time" value="${entry.e}" oninput="updateEntry(${i},'e',this.value)">
                <input type="number" value="${entry.b}" placeholder="0" oninput="updateEntry(${i},'b',this.value)">
                <span class="day-total">${(diff/60).toFixed(2)}h</span>
                ${job.mode==='custom'?`<button class="remove-btn" onclick="removeRow(${i})">×</button>`:`<span></span>`}
            </div>`;
        });

        document.getElementById('grandTotal').innerText = `${Math.floor(totalMin/60)}h ${totalMin%60}m`;
        document.getElementById('grandPay').innerText = `${data.currency}${((totalMin/60) * job.wage).toFixed(2)}`;
    }

    function exportCSV() {
        const job = data.jobs[data.currentJob];
        const list = job.mode === 'weekly' ? job.weekly : job.custom;
        let csv = "Date,Description,Start,End,BreakMin,DecimalHours,EstimatedPay\n";
        list.forEach(e => {
            if(!e.s || !e.e) return;
            const [sH, sM] = e.s.split(':').map(Number);
            const [eH, eM] = e.e.split(':').map(Number);
            let start = sH * 60 + sM; let end = eH * 60 + eM; if(end < start) end += 1440;
            let netMin = Math.max(0, (end - start) - (e.b || 0));
            let hours = (netMin / 60).toFixed(2);
            csv += `${e.dt || 'No Date'},${data.currentJob},${e.s},${e.e},${e.b},${hours},${(hours * job.wage).toFixed(2)}\n`;
        });
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = `Accounting_${data.currentJob}.csv`; a.click();
    }
    render();
</script>
</body>
</html>
